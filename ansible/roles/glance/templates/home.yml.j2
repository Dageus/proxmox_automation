{%- set ns = namespace(services=[]) %}
{%- for host in groups['all'] %}
  {%- if hostvars[host]['services'] is defined %}
    {%- for svc in hostvars[host]['services'] %}
      {%- if svc['icon'] is defined %}
        {%- set ns.services = ns.services + [svc] %}
      {%- endif %}
    {%- endfor %}
  {%- endif %}
{%- endfor %}

- name: Home
  # width: slim
  # hide-desktop-navigation: true
  center-vertically: true
  columns:
    # ==========================================
    # COLUMN 1: Homelab Navigation & Utilities
    # ==========================================
    - size: small
      widgets:
        - type: calendar
          first-day-of-week: monday

        - type: weather
          location: Lisbon, Portugal
          units: metric
          hour-format: 24h
          show-area-name: true

    - size: full
      widgets:
        - type: split-column
          widgets:
            - type: search
              search-engine: google
              bangs:
                - title: YouTube
                  shortcut: "!yt"
                  url: https://www.youtube.com/results?search_query={QUERY}
                - title: Reddit
                  shortcut: "!r"
                  url: https://www.reddit.com/search?q={QUERY}
                - title: GitHub
                  shortcut: "!gh"
                  url: https://github.com/search?q={QUERY}

            - type: clock
              hour-format: 24h
              timezone: Europe/Lisbon

        - type: monitor
          cache: 1m
          title: Service
          sites:
            {%- for svc in ns.services %}

              - title: {{ svc.subdomain | capitalize }}
                url: "https://{{ svc.subdomain }}.jmnogueira.pt"
                icon: "{{ svc.icon | default('si:server') }}"
            {%- endfor %}

        - type: iframe
          label: Proxmox
          source: https://your_iframe_url_1
          height: 400
